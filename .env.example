# ============================================================
# soc-n8n-workflows — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# In n8n, these map to Credentials (Settings > Credentials),
# not literal env vars — names below match the placeholder
# credential names used inside the workflow JSON files.
# ============================================================

# --- LLM ---
# Used by: 01, 02, 04, 06, 08, 09, 10
OPENAI_API_KEY=sk-REPLACE_ME
# Alternative if you swap the OpenAI node for Anthropic:
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Threat Intelligence ---
# Used by: 02, 03, 04
VIRUSTOTAL_API_KEY=REPLACE_ME
# Used by: 03, 04
ABUSEIPDB_API_KEY=REPLACE_ME
# Used by: 03 (optional branch, disabled by default)
SHODAN_API_KEY=REPLACE_ME
# Used by: 08 (AlienVault OTX)
OTX_API_KEY=REPLACE_ME
# Used by: 07 (HaveIBeenPwned - requires paid key for domain search)
HIBP_API_KEY=REPLACE_ME

# --- Notification / Ticketing ---
# Used by: almost all workflows (Slack Bot token, chat:write scope)
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SOC_CHANNEL=#soc-alerts
SLACK_SOC_ESCALATION_CHANNEL=#soc-escalations
# Used by: 02, 10 (Jira Cloud API token)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=soc-bot@example.com
JIRA_API_TOKEN=REPLACE_ME
JIRA_PROJECT_KEY=SOC
# Used by: 05, 06, 08, 09 (SMTP for email digests/reports)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=soc-reports@example.com
SMTP_PASSWORD=REPLACE_ME

# --- Identity / EDR (mocked in this repo) ---
# Used by: 04 (containment actions), 07 (password reset)
OKTA_BASE_URL=https://your-org.okta.com
OKTA_API_TOKEN=REPLACE_ME
EDR_BASE_URL=https://api.crowdstrike.com
EDR_CLIENT_ID=REPLACE_ME
EDR_CLIENT_SECRET=REPLACE_ME

# --- Internal (mock) services ---
# Used by: 05 (cloud inventory), 09 (SOC metrics store)
CLOUD_INVENTORY_API=https://internal.example.com/api/cloud-inventory
SOC_METRICS_API=https://internal.example.com/api/soc-metrics

# --- Optional detonation / TIP push ---
# Used by: 02 (disabled urlscan.io branch)
URLSCAN_API_KEY=REPLACE_ME

# --- n8n instance ---
N8N_WEBHOOK_BASE_URL=https://n8n.example.com
# Shared secret required by all webhook triggers (header-auth credential,
# e.g. header "X-Webhook-Token"). Used by: 01, 02, 03, 04, 10, 11
WEBHOOK_SHARED_SECRET=REPLACE_ME
