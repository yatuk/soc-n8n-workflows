      "id": "c3000003-0001-4c03-9003-000000000001",
      "name": "IOC List Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-1200, 100],
      "webhookId": "c3000003-0001-4c03-9003-00000000ffff",
      "credentials": {
        "httpHeaderAuth": { "id": "PLACEHOLDER", "name": "Webhook Shared Secret - PLACEHOLDER" }
      }
