      "id": "c3000003-0013-4c03-9003-000000000013",
      "name": "Merge Intel Streams",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [480, 100]
    },
    {
      "parameters": {
        "jsCode": "// Normalize all sources into flat rows and compute a 0-100 composite\n// risk score. Weighting: VT detection ratio 70%, AbuseIPDB confidence 30%\n// (VT-only sources are weighted 100% VT). All-sources-failed => lookup_failed.\nconst rows = $input.all().map(({ json: r }) => {\n  if (r.type === 'unsupported') {\n    return { batch_id: r.batch_id, ioc: r.ioc, type: r.type, risk_score: null, risk_level: 'unknown', vt_malicious: null, vt_total_engines: null, abuse_confidence: null, shodan_open_ports: null, notes: 'unsupported IOC format' };\n  }\n  const stats = r.vt?.data?.attributes?.last_analysis_stats ?? null;\n  const total = stats ? Object.values(stats).reduce((a, b) => a + (Number(b) || 0), 0) : 0;\n  const vtScore = stats && total > 0 ? Math.min(1, ((stats.malicious ?? 0) + 0.5 * (stats.suspicious ?? 0)) / Math.max(1, total * 0.25)) : null;\n  const abuseConf = r.abuseipdb?.data?.abuseConfidenceScore ?? null;\n  const ports = r.shodan?.ports ?? null;\n\n  let score = null;\n  if (vtScore !== null && abuseConf !== null) score = Math.round(vtScore * 70 + (abuseConf / 100) * 30);\n  else if (vtScore !== null) score = Math.round(vtScore * 100);\n  else if (abuseConf !== null) score = Math.round(abuseConf);\n\n  const level = score === null ? 'lookup_failed' : score >= 70 ? 'high' : score >= 40 ? 'medium' : score >= 10 ? 'low' : 'clean';\n  return {\n    batch_id: r.batch_id,\n    ioc: r.ioc,\n    type: r.type,\n    risk_score: score,\n    risk_level: level,\n    vt_malicious: stats?.malicious ?? null,\n    vt_total_engines: total || null,\n    abuse_confidence: abuseConf,\n    shodan_open_ports: ports ? ports.join(';') : null,\n    notes: score === null ? 'all intel lookups failed' : '',\n  };\n});\n\n// Highest risk first — the analyst reads top-down.\nrows.sort((a, b) => (b.risk_score ?? -1) - (a.risk_score ?? -1));\nreturn rows.map(r => ({ json: r }));"
      },
