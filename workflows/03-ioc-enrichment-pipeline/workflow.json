      },
      "id": "c3000003-0006-4c03-9003-000000000006",
      "name": "Shodan: Host Context (optional)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [0, -180],
      "disabled": true,
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Re-attach the original IOC to every intel source. Each source is\n// nullable — an API outage becomes 'lookup_failed', never a dropped IOC.\nconst ioc = $('Classify IOCs').item.json;\nlet vt = null, abuse = null, shodan = null;\ntry { const v = $('VirusTotal: IP Report').item.json; if (v?.data) vt = v; } catch (e) {}\ntry { const a = $('AbuseIPDB: Check IP').item.json; if (a?.data) abuse = a; } catch (e) {}\ntry { const s = $('Shodan: Host Context (optional)').item.json; if (s && !s.error) shodan = s; } catch (e) {}\nreturn { json: { ...ioc, vt, abuseipdb: abuse, shodan } };"
      },
      "id": "c3000003-0007-4c03-9003-000000000007",
      "name": "Combine IP Intel",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, -180]
