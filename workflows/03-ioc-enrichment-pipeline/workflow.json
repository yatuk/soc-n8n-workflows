    {
      "parameters": {
        "jsCode": "// Classify each submitted IOC by shape. One output item per IOC.\nconst body = $json.body ?? $json;\nconst iocs = (body.iocs ?? []).map(s => String(s).trim()).filter(Boolean);\nif (iocs.length === 0) {\n  throw new Error('No IOCs supplied. POST {\"iocs\": [\"1.2.3.4\", \"evil.com\", \"<sha256>\"]}');\n}\n\nconst ipv4 = /^(?:(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)\\.){3}(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)$/;\nconst hash = /^[a-fA-F0-9]{32}$|^[a-fA-F0-9]{40}$|^[a-fA-F0-9]{64}$/;\nconst domain = /^(?=.{4,253}$)(([a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)\\.)+[a-zA-Z]{2,}$/;\n\nreturn iocs.slice(0, 50).map(ioc => {\n  let type = 'unsupported';\n  if (ipv4.test(ioc)) type = 'ip';\n  else if (hash.test(ioc)) type = 'hash';\n  else if (domain.test(ioc)) type = 'domain';\n  return { json: { ioc, type, batch_id: body.batch_id ?? `ioc-batch-${Date.now()}` } };\n});"
      },
      "id": "c3000003-0002-4c03-9003-000000000002",
      "name": "Classify IOCs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-960, 100]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "type-ip",
                    "leftValue": "={{ $json.type }}",
                    "rightValue": "ip",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "IP"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "type-hash",
                    "leftValue": "={{ $json.type }}",
                    "rightValue": "hash",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Hash"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "type-domain",
                    "leftValue": "={{ $json.type }}",
                    "rightValue": "domain",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Domain"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "c3000003-0003-4c03-9003-000000000003",
